---
// src/layouts/BlogPost.astro
import BaseLayout from './BaseLayout.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  author: string;
  authorRole: string;
  tags: string[];
  headings: Heading[];
}

const { title, description, publishDate, author, authorRole, tags, headings } = Astro.props;

const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Sulphur Blog`} description={description}>
  <!-- Reading progress bar -->
  <div id="reading-progress"></div>

  <div class="blog-post-page">
    <!-- Post Header -->
    <header class="post-header">
      <div class="post-header-inner">
        <div class="post-tags">
          {tags.map(tag => (
            <span class="post-tag">#{tag}</span>
          ))}
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-meta">
          <div class="post-author">
            <div class="author-avatar">
              {author.charAt(0)}
            </div>
            <div>
              <div class="author-name">{author}</div>
              <div class="author-role">{authorRole}</div>
            </div>
          </div>
          <time class="post-date" datetime={publishDate.toISOString()}>
            {formattedDate}
          </time>
        </div>
      </div>
    </header>

    <!-- Main content area with optional ToC sidebar -->
    <div class="post-body">
      <!-- ToC sidebar (desktop only) -->
      {tocHeadings.length > 0 && (
        <aside class="toc-sidebar">
          <div class="toc-sticky">
            <h2 class="toc-title">On this page</h2>
            <nav class="toc-nav">
              {tocHeadings.map(h => (
                <a
                  href={`#${h.slug}`}
                  class={`toc-link toc-depth-${h.depth}`}
                  data-heading={h.slug}
                >
                  {h.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}

      <!-- Article content -->
      <article class="post-content prose">
        <slot />
      </article>
    </div>
  </div>

  <style>
    .blog-post-page {
      min-height: 100vh;
      background: var(--color-bg);
    }

    /* Header */
    .post-header {
      background: linear-gradient(135deg, rgba(108, 99, 255, 0.08) 0%, rgba(0, 212, 255, 0.05) 100%);
      border-bottom: 1px solid var(--color-border);
      padding: 5rem 1.5rem 3rem;
    }

    .post-header-inner {
      max-width: 800px;
      margin: 0 auto;
    }

    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1.25rem;
    }

    .post-tag {
      font-size: 0.75rem;
      font-family: 'Geist Mono', monospace;
      color: var(--color-accent-primary);
      background: rgba(108, 99, 255, 0.1);
      border: 1px solid rgba(108, 99, 255, 0.2);
      border-radius: 0.375rem;
      padding: 0.25rem 0.625rem;
    }

    .post-title {
      font-size: clamp(1.75rem, 4vw, 3rem);
      font-weight: 800;
      line-height: 1.15;
      color: #ffffff;
      margin: 0 0 1rem;
    }

    .post-description {
      font-size: 1.125rem;
      color: var(--color-text-secondary);
      line-height: 1.7;
      margin: 0 0 1.5rem;
    }

    .post-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .post-author {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .author-avatar {
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary));
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1rem;
      color: white;
      flex-shrink: 0;
    }

    .author-name {
      font-weight: 600;
      color: var(--color-text-primary);
      font-size: 0.9rem;
    }

    .author-role {
      color: var(--color-text-secondary);
      font-size: 0.8rem;
    }

    .post-date {
      color: var(--color-text-secondary);
      font-size: 0.875rem;
      font-family: 'Geist Mono', monospace;
    }

    /* Body layout */
    .post-body {
      display: grid;
      grid-template-columns: 1fr;
      max-width: 1200px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
      gap: 3rem;
    }

    @media (min-width: 1024px) {
      .post-body {
        grid-template-columns: 220px 1fr;
      }
    }

    /* ToC sidebar */
    .toc-sidebar {
      display: none;
    }

    @media (min-width: 1024px) {
      .toc-sidebar {
        display: block;
      }
    }

    .toc-sticky {
      position: sticky;
      top: 2rem;
    }

    .toc-title {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-text-secondary);
      margin: 0 0 0.75rem;
    }

    .toc-nav {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .toc-link {
      font-size: 0.875rem;
      color: var(--color-text-secondary);
      text-decoration: none;
      padding: 0.3rem 0.5rem;
      border-left: 2px solid transparent;
      transition: color 0.2s, border-color 0.2s;
      line-height: 1.4;
    }

    .toc-link.toc-depth-3 {
      padding-left: 1.25rem;
      font-size: 0.8rem;
    }

    .toc-link:hover,
    .toc-link.active {
      color: var(--color-accent-primary);
      border-left-color: var(--color-accent-primary);
    }

    /* Article prose */
    .post-content {
      max-width: 720px;
      min-width: 0;
    }

    /* Shiki code block overrides */
    .post-content :global(pre) {
      border-radius: 0.75rem;
      border: 1px solid var(--color-border);
      margin: 1.5rem 0;
      overflow-x: auto;
    }

    .post-content :global(pre code) {
      font-family: 'Geist Mono', monospace;
      font-size: 0.875rem;
    }

    .post-content :global(img) {
      border-radius: 0.75rem;
      max-width: 100%;
      height: auto;
    }

    .post-content :global(blockquote) {
      border-left: 3px solid var(--color-accent-primary);
      background: rgba(108, 99, 255, 0.05);
      border-radius: 0 0.5rem 0.5rem 0;
      padding: 1rem 1.25rem;
      margin: 1.5rem 0;
    }
  </style>

  <script>
    // Reading progress bar
    const bar = document.getElementById('reading-progress');
    if (bar) {
      const update = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        bar.style.width = `${Math.min(progress, 100)}%`;
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }

    // ToC active section highlighting via IntersectionObserver
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link[data-heading]');
    if (tocLinks.length > 0) {
      const headingEls = Array.from(tocLinks).map(link => {
        const slug = link.dataset.heading!;
        return document.getElementById(slug);
      }).filter(Boolean) as HTMLElement[];

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              tocLinks.forEach(l => l.classList.remove('active'));
              const slug = entry.target.id;
              const activeLink = document.querySelector<HTMLAnchorElement>(`.toc-link[data-heading="${slug}"]`);
              if (activeLink) activeLink.classList.add('active');
            }
          });
        },
        { rootMargin: '0px 0px -60% 0px', threshold: 0 }
      );

      headingEls.forEach(el => observer.observe(el));
    }
  </script>
</BaseLayout>
