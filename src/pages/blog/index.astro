---
// src/pages/blog/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Fetch all non-draft posts, sorted newest first
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

// Featured post: first post marked featured, fallback to newest
const featuredPost = allPosts.find(p => p.data.featured) ?? allPosts[0];
// Grid posts: all except featured (pagination: 9 per page)
const POSTS_PER_PAGE = 9;
const gridPosts = allPosts.filter(p => p.id !== featuredPost?.id).slice(0, POSTS_PER_PAGE);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Blog — Sulphur AI Swarm"
  description="Technical insights, engineering deep-dives, and announcements from the Sulphur AI Swarm team."
>
  <div class="blog-page">
    <!-- Page Hero -->
    <section class="blog-hero">
      <div class="hero-inner">
        <div class="hero-label">From the Swarm</div>
        <h1 class="hero-title">Blog</h1>
        <p class="hero-subtitle">
          Technical insights, engineering deep-dives, and announcements from
          the Sulphur AI Swarm — written by the swarm, for the curious.
        </p>
      </div>
    </section>

    <div class="blog-content">
      <!-- Featured Post -->
      {featuredPost && (
        <section class="featured-section" id="featured-post">
          <div class="section-label">Featured</div>
          <a href={`/blog/${featuredPost.id}/`} class="featured-card glass-card">
            <div class="featured-card-content">
              <div class="featured-tags">
                {featuredPost.data.tags.slice(0, 3).map(tag => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
              <h2 class="featured-title">{featuredPost.data.title}</h2>
              <p class="featured-description">{featuredPost.data.description}</p>
              <div class="featured-meta">
                <span class="meta-author">{featuredPost.data.author}</span>
                <span class="meta-dot">·</span>
                <time class="meta-date">{formatDate(featuredPost.data.publishDate)}</time>
              </div>
              <span class="read-more">Read article →</span>
            </div>
          </a>
        </section>
      )}

      <!-- Posts Grid -->
      {gridPosts.length > 0 && (
        <section class="grid-section">
          <div class="section-label">All Posts</div>
          <div class="posts-grid" id="posts-grid">
            {gridPosts.map(post => (
              <a href={`/blog/${post.id}/`} class="post-card glass-card">
                <div class="card-tags">
                  {post.data.tags.slice(0, 2).map(tag => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
                <h3 class="card-title">{post.data.title}</h3>
                <p class="card-description">{post.data.description}</p>
                <div class="card-meta">
                  <span class="meta-author">{post.data.author}</span>
                  <time class="meta-date">{formatDate(post.data.publishDate)}</time>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      {allPosts.length === 0 && (
        <div class="empty-state">
          <p>No posts yet. Check back soon.</p>
        </div>
      )}
    </div>
  </div>

  <style>
    .blog-page {
      min-height: 100vh;
      background: var(--color-bg);
    }

    /* Hero */
    .blog-hero {
      padding: 6rem 1.5rem 4rem;
      text-align: center;
      background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(108, 99, 255, 0.12), transparent);
      border-bottom: 1px solid var(--color-border);
    }

    .hero-inner {
      max-width: 700px;
      margin: 0 auto;
    }

    .hero-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--color-accent-primary);
      font-family: 'Geist Mono', monospace;
      margin-bottom: 1rem;
    }

    .hero-title {
      font-size: clamp(3rem, 8vw, 5rem);
      font-weight: 800;
      margin: 0 0 1rem;
      color: #ffffff;
    }

    .hero-subtitle {
      font-size: 1.125rem;
      color: var(--color-text-secondary);
      line-height: 1.7;
      margin: 0;
    }

    /* Content */
    .blog-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
      display: flex;
      flex-direction: column;
      gap: 3.5rem;
    }

    .section-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--color-text-secondary);
      font-family: 'Geist Mono', monospace;
      margin-bottom: 1.25rem;
    }

    /* Glass card base */
    .glass-card {
      display: block;
      text-decoration: none;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--color-border);
      border-radius: 1rem;
      transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
    }

    .glass-card:hover {
      transform: translateY(-4px);
      border-color: rgba(108, 99, 255, 0.3);
      background: rgba(108, 99, 255, 0.04);
    }

    /* Featured card */
    .featured-card {
      padding: 2.5rem;
    }

    .featured-card-content {
      max-width: 700px;
    }

    .featured-title {
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 700;
      color: #ffffff;
      margin: 0.75rem 0 0.75rem;
      line-height: 1.25;
    }

    .featured-description {
      font-size: 1.0625rem;
      color: var(--color-text-secondary);
      line-height: 1.7;
      margin: 0 0 1.25rem;
    }

    .featured-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.25rem;
      font-size: 0.875rem;
      color: var(--color-text-secondary);
    }

    .meta-dot {
      opacity: 0.4;
    }

    .read-more {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-accent-primary);
    }

    /* Post tags */
    .featured-tags,
    .card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
      margin-bottom: 0.875rem;
    }

    .tag {
      font-size: 0.7rem;
      font-family: 'Geist Mono', monospace;
      color: var(--color-accent-secondary);
      background: rgba(0, 212, 255, 0.07);
      border: 1px solid rgba(0, 212, 255, 0.15);
      border-radius: 0.3rem;
      padding: 0.2rem 0.5rem;
    }

    /* Posts grid */
    .posts-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    @media (min-width: 640px) {
      .posts-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .posts-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .post-card {
      padding: 1.75rem;
      display: flex;
      flex-direction: column;
    }

    .card-title {
      font-size: 1.125rem;
      font-weight: 700;
      color: #ffffff;
      margin: 0 0 0.625rem;
      line-height: 1.35;
    }

    .card-description {
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      line-height: 1.65;
      margin: 0 0 1rem;
      flex: 1;
    }

    .card-meta {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      font-size: 0.8rem;
      color: var(--color-text-secondary);
      margin-top: auto;
    }

    .meta-author {
      font-weight: 500;
      color: var(--color-text-primary);
    }

    .empty-state {
      text-align: center;
      color: var(--color-text-secondary);
      padding: 4rem 0;
    }
  </style>

  <!-- GSAP ScrollTrigger entrance animations -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script is:inline>
    gsap.registerPlugin(ScrollTrigger);

    // Animate featured post
    const featured = document.getElementById('featured-post');
    if (featured) {
      gsap.fromTo(featured,
        { opacity: 0, y: 40 },
        {
          opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
          scrollTrigger: { trigger: featured, start: 'top 85%', once: true }
        }
      );
    }

    // Staggered grid card entrance
    const cards = document.querySelectorAll('#posts-grid .post-card');
    if (cards.length > 0) {
      gsap.fromTo(cards,
        { opacity: 0, y: 30 },
        {
          opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', stagger: 0.1,
          scrollTrigger: { trigger: '#posts-grid', start: 'top 85%', once: true }
        }
      );
    }
  </script>
</BaseLayout>
