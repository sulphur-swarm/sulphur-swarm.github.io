---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Mission from '../components/sections/Mission.astro';
import Capabilities from '../components/sections/Capabilities.astro';
import Projects from '../components/sections/Projects.astro';
import CTA from '../components/sections/CTA.astro';
---

<BaseLayout
  title="Sulphur AI Swarm — The Most Capable AI System"
  description="Sulphur is a distributed multi-agent AI swarm delivering superhuman software engineering, analysis, and automation."
>
  <!-- Hero Section -->
  <section id="hero"
           style="display: flex; align-items: center; justify-content: center; min-height: calc(100vh - 4rem); text-align: center; padding: 2rem;">
    <div>
      <!-- Eyebrow label -->
      <p style="font-family: 'Geist Mono', monospace; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-accent-secondary); margin-bottom: 1.5rem;">
        Sulphur AI Swarm
      </p>

      <!-- Main headline -->
      <h1 style="font-size: clamp(2.5rem, 8vw, 6rem); font-weight: 800; line-height: 1.1; margin: 0 0 1.5rem; color: var(--color-text-primary);">
        The most capable<br />AI system to date.
      </h1>

      <!-- Subheadline -->
      <p style="font-size: 1.25rem; color: var(--color-text-secondary); max-width: 560px; margin: 0 auto 2.5rem; line-height: 1.7;">
        Sulphur is a distributed multi-agent AI swarm delivering superhuman
        software engineering, analysis, and automation.
      </p>

      <!-- CTAs -->
      <div style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center;">
        <a href="/swarmfix/"
           style="display: inline-block; background: var(--color-accent-primary); color: white; padding: 0.875rem 2rem; border-radius: 0.5rem; font-weight: 600; text-decoration: none; font-size: 1rem;">
          Explore SwarmFix
        </a>
        <a href="#mission"
           style="display: inline-block; border: 1px solid var(--color-border); color: var(--color-text-primary); padding: 0.875rem 2rem; border-radius: 0.5rem; font-weight: 600; text-decoration: none; font-size: 1rem;">
          Learn how it works
        </a>
      </div>

      <!-- Scroll indicator -->
      <div style="margin-top: 4rem; color: var(--color-text-secondary); font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;">
        <div style="width: 1px; height: 48px; background: var(--color-border); margin: 0 auto 0.75rem;"></div>
        Scroll
      </div>
    </div>
  </section>

  <!-- Content Sections -->
  <Mission />
  <Capabilities />
  <Projects />
  <CTA />

  <!-- Hero GSAP entrance animation -->
  <script>
    import gsap from 'gsap';

    gsap.from('#hero h1', {
      opacity: 0,
      y: 30,
      duration: 1.0,
      ease: 'power2.out',
      delay: 0.2,
    });
    gsap.from('#hero p, #hero div[style*="flex"]', {
      opacity: 0,
      y: 20,
      duration: 0.9,
      ease: 'power2.out',
      delay: 0.5,
      stagger: 0.15,
    });
  </script>

</BaseLayout>
