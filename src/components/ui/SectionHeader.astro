---
// src/components/ui/SectionHeader.astro
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  gradient?: boolean;
  align?: 'left' | 'center';
}
const { eyebrow, title, subtitle, gradient = true, align = 'center' } = Astro.props;
---
<div class:list={['section-header', align === 'center' && 'text-center']}>
  {eyebrow && (
    <p class="eyebrow">{eyebrow}</p>
  )}
  <h2 class:list={['section-title', gradient && 'gradient-text']}>{title}</h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
</div>

<style>
  .section-header { margin-bottom: 3rem; }
  .eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-primary);
    margin-bottom: 0.75rem;
    margin-top: 0;
  }
  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
  }
  .gradient-text {
    background: linear-gradient(135deg, #fff 0%, var(--color-accent-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .section-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0;
  }
  .text-center { text-align: center; }
  .text-center .section-subtitle { margin: 0 auto; }
</style>
