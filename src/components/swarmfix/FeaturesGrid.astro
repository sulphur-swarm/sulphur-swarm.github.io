---
// src/components/swarmfix/FeaturesGrid.astro
import SectionHeader from '../ui/SectionHeader.astro';

const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v10m0 0h10M9 13H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2zm10 0h-4a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-4a2 2 0 00-2-2z"/></svg>`,
    title: 'Multi-Agent Coordination',
    description: 'Researcher, Planner, Worker, and Validator agents collaborate on every fix — each specialized, each accountable.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Language Agnostic',
    description: "Works across JavaScript, TypeScript, Python, Go, Rust, Ruby, and more. If it's code, the swarm can fix it.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
    title: 'Context Aware',
    description: 'Reads full codebase context — not just the affected file. Deep understanding of your architecture and patterns.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>`,
    title: 'Explainable Fixes',
    description: 'Every change ships with a plain-English explanation of what was changed, why, and what to watch for.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Safe by Design',
    description: 'Fixes are validated before delivery. Validator agents run tests and checks — no untested patches reach your repo.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
    title: 'Open Source First',
    description: 'Built for the OSS community. The free tier is genuinely free — no catch, no expiry, just fixes.',
  },
];
---

<section class="features-section">
  <div class="features-container">
    <SectionHeader
      eyebrow="Capabilities"
      title="Everything you need to ship fixes"
      subtitle="SwarmFix is built for the full lifecycle — from analysis to delivery."
    />

    <div class="features-grid">
      {features.map((f) => (
        <div class="feature-card">
          <div class="feature-icon" set:html={f.icon} />
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 6rem 1.5rem;
    background: var(--color-surface);
    position: relative;
  }
  .features-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(108,99,255,0.3), transparent);
  }
  .features-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .features-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .feature-card {
    background: rgba(8, 9, 12, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1rem;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
    opacity: 0;
    transform: translateY(24px);
  }
  .feature-card:hover {
    transform: translateY(-3px) !important;
    border-color: rgba(108, 99, 255, 0.3);
    box-shadow: 0 8px 30px rgba(108, 99, 255, 0.1);
  }
  .feature-icon {
    width: 44px;
    height: 44px;
    color: var(--color-accent-primary);
    margin-bottom: 1rem;
  }
  .feature-icon svg { width: 100%; height: 100%; }
  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }
  .feature-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.feature-card', {
    opacity: 1,
    y: 0,
    duration: 0.5,
    stagger: 0.1,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '.features-grid',
      start: 'top 80%',
      once: true,
    },
  });
</script>
