---
// src/components/swarmfix/ProblemSolution.astro
---

<section class="pitch-section">
  <div class="pitch-container">

    <!-- Left: Problem -->
    <div class="pitch-col problem-col">
      <div class="col-eyebrow problem-eyebrow">The Problem</div>
      <h2 class="col-title">Bugs pile up.<br/>Issues go stale.<br/>Maintainers burn out.</h2>
      <p class="col-body">
        Open source is the backbone of modern software, yet maintainers face an impossible backlog.
        Issues multiply, contributors drift, and bugs linger for months — or forever.
      </p>
      <ul class="problem-list">
        <li>⏳ Average issue sits open for 30+ days</li>
        <li>🔥 Maintainer burnout is at an all-time high</li>
        <li>🕳 Critical bugs get lost in the noise</li>
      </ul>
    </div>

    <!-- Divider arrow -->
    <div class="pitch-divider" aria-hidden="true">
      <svg viewBox="0 0 40 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 4L36 40L4 76" stroke="rgba(108,99,255,0.4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <!-- Right: Solution -->
    <div class="pitch-col solution-col">
      <div class="col-eyebrow solution-eyebrow">The Solution</div>
      <h2 class="col-title solution-title">Autonomous bug fixing,<br/>at scale.</h2>
      <p class="col-body">
        SwarmFix deploys a coordinated agent swarm to analyze, plan, implement, and validate
        code fixes — autonomously. No human in the loop required.
      </p>
      <ul class="solution-list">
        <li>🤖 Multi-agent swarm: Researcher → Planner → Worker → Validator</li>
        <li>⚡ Average fix delivered in under 2 hours</li>
        <li>✅ Validated patches only — no broken code ships</li>
      </ul>
    </div>

  </div>
</section>

<style>
  .pitch-section {
    padding: 6rem 1.5rem;
    background: var(--color-surface);
    position: relative;
  }
  .pitch-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(108,99,255,0.25), transparent);
  }

  .pitch-container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .pitch-container { grid-template-columns: 1fr auto 1fr; gap: 2rem; }
  }

  .pitch-divider {
    width: 40px;
    display: none;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .pitch-divider { display: block; }
  }

  .col-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .problem-eyebrow { color: rgba(255, 100, 100, 0.8); }
  .solution-eyebrow { color: var(--color-accent-primary); }

  .col-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-text-primary);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .solution-title {
    background: linear-gradient(135deg, #fff 0%, var(--color-accent-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .col-body {
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
  }

  .problem-list, .solution-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .problem-list li, .solution-list li {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .problem-col {
    background: rgba(255, 60, 60, 0.03);
    border: 1px solid rgba(255, 60, 60, 0.08);
    border-radius: 1rem;
    padding: 2rem;
    opacity: 0;
    transform: translateX(-30px);
  }
  .solution-col {
    background: rgba(108, 99, 255, 0.05);
    border: 1px solid rgba(108, 99, 255, 0.15);
    border-radius: 1rem;
    padding: 2rem;
    opacity: 0;
    transform: translateX(30px);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.problem-col', {
    opacity: 1,
    x: 0,
    duration: 0.7,
    ease: 'power2.out',
    scrollTrigger: { trigger: '.pitch-section', start: 'top 80%', once: true },
  });
  gsap.to('.solution-col', {
    opacity: 1,
    x: 0,
    duration: 0.7,
    ease: 'power2.out',
    delay: 0.15,
    scrollTrigger: { trigger: '.pitch-section', start: 'top 80%', once: true },
  });
</script>
