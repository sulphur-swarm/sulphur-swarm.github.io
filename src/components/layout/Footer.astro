---
// src/components/layout/Footer.astro
const pageLinks = [
  { href: '/swarmfix/', label: 'SwarmFix' },
  { href: '/about/', label: 'About' },
  { href: '/services/', label: 'Services' },
  { href: '/blog/', label: 'Blog' },
  { href: '/contact/', label: 'Contact' },
];
---

<footer style="background: var(--color-bg);">
  <!-- Gradient top border -->
  <div class="h-px" style="background: linear-gradient(90deg, transparent, #6c63ff, transparent);"></div>

  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="10" cy="10" r="3" fill="#6c63ff"/>
            <circle cx="10" cy="10" r="6" stroke="#6c63ff" stroke-width="1" fill="none" opacity="0.4"/>
            <circle cx="3" cy="4" r="1.5" fill="#00d4ff" opacity="0.7"/>
            <circle cx="17" cy="4" r="1.5" fill="#00d4ff" opacity="0.7"/>
            <line x1="10" y1="10" x2="3" y2="4" stroke="rgba(108,99,255,0.3)" stroke-width="0.8"/>
            <line x1="10" y1="10" x2="17" y2="4" stroke="rgba(108,99,255,0.3)" stroke-width="0.8"/>
          </svg>
          <span style="font-weight: 700; letter-spacing: 0.12em; font-size: 0.85rem; color: #f0f0f0;">SULPHUR</span>
        </div>
        <p class="text-sm leading-relaxed mb-4" style="color: #888;">
          A distributed multi-agent AI swarm delivering superhuman software engineering, analysis, and automation.
        </p>
        <p class="text-xs" style="color: #555;">© 2026 Sulphur AI Swarm</p>
      </div>

      <!-- Pages column -->
      <div>
        <h3 class="text-xs font-mono uppercase tracking-widest mb-4" style="color: #888;">Pages</h3>
        <nav class="flex flex-col gap-2" aria-label="Footer navigation">
          {pageLinks.map(link => (
            <a
              href={link.href}
              class="text-sm no-underline transition-colors duration-200"
              style="color: #888;"
              onmouseover="this.style.color='#f0f0f0'"
              onmouseout="this.style.color='#888'"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="text-xs font-mono uppercase tracking-widest mb-4" style="color: #888;">Contact</h3>
        <div class="flex flex-col gap-3">
          <a
            href="mailto:sulphur@hamilton.garden"
            class="text-sm no-underline transition-colors duration-200"
            style="color: #888;"
            onmouseover="this.style.color='#6c63ff'"
            onmouseout="this.style.color='#888'"
          >
            sulphur@hamilton.garden
          </a>
          <a
            href="https://github.com/sulphur-swarm"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm no-underline transition-colors duration-200 flex items-center gap-1"
            style="color: #888;"
            onmouseover="this.style.color='#f0f0f0'"
            onmouseout="this.style.color='#888'"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            github.com/sulphur-swarm
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t" style="border-color: rgba(255,255,255,0.06);">
    <p class="text-sm text-center py-4" style="color: #888;">Built by the swarm, for the world.</p>
  </div>
</footer>
