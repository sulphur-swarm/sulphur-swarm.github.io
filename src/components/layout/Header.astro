---
// src/components/layout/Header.astro
---
<header id="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="logo-link">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="12" cy="12" r="4" fill="var(--color-accent-primary)" opacity="0.9"/>
        <circle cx="12" cy="12" r="7" stroke="var(--color-accent-primary)" stroke-width="1" opacity="0.3"/>
        <line x1="12" y1="2" x2="12" y2="5" stroke="var(--color-accent-primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <line x1="12" y1="19" x2="12" y2="22" stroke="var(--color-accent-primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <line x1="2" y1="12" x2="5" y2="12" stroke="var(--color-accent-primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <line x1="19" y1="12" x2="22" y2="12" stroke="var(--color-accent-primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <line x1="4.93" y1="4.93" x2="7.05" y2="7.05" stroke="var(--color-accent-primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
        <line x1="16.95" y1="16.95" x2="19.07" y2="19.07" stroke="var(--color-accent-primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
        <line x1="19.07" y1="4.93" x2="16.95" y2="7.05" stroke="var(--color-accent-primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
        <line x1="7.05" y1="16.95" x2="4.93" y2="19.07" stroke="var(--color-accent-primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
      </svg>
      <span class="logo-text">SULPHUR</span>
    </a>

    <!-- Desktop nav links -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <a href="/" class="nav-link">Home</a>
      <a href="/swarmfix/" class="nav-link">SwarmFix</a>
      <a href="/about/" class="nav-link">About</a>
      <a href="/services/" class="nav-link">Services</a>
      <a href="/blog/" class="nav-link">Blog</a>
      <a href="/contact/" class="nav-link">Contact</a>
    </nav>

    <!-- CTA button (desktop) + hamburger (mobile) -->
    <a href="/contact/" class="cta-btn" aria-label="Get started">Get Started</a>
    <button id="mobile-menu-btn" class="hamburger-btn" aria-label="Open menu" aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="19" y2="6"/>
        <line x1="3" y1="11" x2="19" y2="11"/>
        <line x1="3" y1="16" x2="19" y2="16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile overlay menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <button id="mobile-close-btn" class="mobile-close-btn" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <nav class="mobile-nav" aria-label="Mobile navigation">
      <a href="/" class="mobile-nav-link">Home</a>
      <a href="/swarmfix/" class="mobile-nav-link">SwarmFix</a>
      <a href="/about/" class="mobile-nav-link">About</a>
      <a href="/services/" class="mobile-nav-link">Services</a>
      <a href="/blog/" class="mobile-nav-link">Blog</a>
      <a href="/contact/" class="mobile-nav-link">Contact</a>
    </nav>
    <a href="/contact/" class="mobile-cta-btn">Get Started</a>
  </div>
</header>

<style>
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(8, 9, 12, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    height: 64px;
  }

  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: 'Geist', sans-serif;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-text-primary);
    font-size: 1rem;
  }

  .desktop-nav {
    display: none;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .desktop-nav { display: flex; }
  }

  .nav-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .nav-link:hover,
  .nav-link[data-active] {
    color: var(--color-accent-primary);
  }

  .cta-btn {
    display: none;
    background: var(--color-accent-primary);
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, box-shadow 0.2s;
  }
  .cta-btn:hover {
    background: #5a51e0;
    box-shadow: 0 0 20px rgba(108, 99, 255, 0.4);
  }

  @media (min-width: 768px) {
    .cta-btn { display: inline-block; }
  }

  .hamburger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: 0.25rem;
  }
  .hamburger-btn:hover { color: var(--color-text-primary); }

  @media (min-width: 768px) {
    .hamburger-btn { display: none; }
  }

  /* Mobile overlay */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(8, 9, 12, 0.97);
    z-index: 100;
    padding: 5rem 2rem 2rem;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mobile-close-btn {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: 0.25rem;
  }
  .mobile-close-btn:hover { color: var(--color-text-primary); }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mobile-nav-link {
    display: block;
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: 1.75rem;
    font-weight: 700;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    opacity: 0;
    transform: translateX(-30px);
  }
  .mobile-nav-link:last-child { border-bottom: none; }
  .mobile-nav-link:hover { color: var(--color-accent-primary); }

  .mobile-cta-btn {
    display: inline-block;
    margin-top: 2rem;
    background: var(--color-accent-primary);
    color: white;
    padding: 0.875rem 2rem;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    opacity: 0;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Scroll-based opacity: increase header bg opacity after 80px
  ScrollTrigger.create({
    start: 80,
    onEnter: () => gsap.to('#site-header', { backgroundColor: 'rgba(8,9,12,0.97)', duration: 0.3 }),
    onLeaveBack: () => gsap.to('#site-header', { backgroundColor: 'rgba(8,9,12,0.85)', duration: 0.3 }),
  });

  // Mobile menu toggle
  const openBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-close-btn');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    if (!menu) return;
    menu.style.display = 'flex';
    menu.setAttribute('aria-hidden', 'false');
    openBtn?.setAttribute('aria-expanded', 'true');
    // GSAP stagger reveal for mobile links
    gsap.fromTo(
      menu.querySelectorAll('.mobile-nav-link'),
      { opacity: 0, x: -30 },
      { opacity: 1, x: 0, stagger: 0.05, duration: 0.3, ease: 'power2.out' }
    );
    gsap.fromTo(
      menu.querySelector('.mobile-cta-btn'),
      { opacity: 0, y: 10 },
      { opacity: 1, y: 0, duration: 0.3, delay: 0.35, ease: 'power2.out' }
    );
  }

  function closeMenu() {
    if (!menu) return;
    menu.style.display = 'none';
    menu.setAttribute('aria-hidden', 'true');
    openBtn?.setAttribute('aria-expanded', 'false');
    // Reset link positions for re-open
    const links = menu.querySelectorAll('.mobile-nav-link');
    links.forEach(link => {
      (link as HTMLElement).style.opacity = '0';
      (link as HTMLElement).style.transform = 'translateX(-30px)';
    });
    const ctaBtn = menu.querySelector('.mobile-cta-btn') as HTMLElement | null;
    if (ctaBtn) ctaBtn.style.opacity = '0';
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Highlight active nav link
  const links = document.querySelectorAll('.nav-link');
  links.forEach(link => {
    if (link.getAttribute('href') === window.location.pathname) {
      link.setAttribute('data-active', '');
    }
  });
</script>
