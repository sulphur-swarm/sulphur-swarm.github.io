---
// src/components/contact/ContactCards.astro
---

<div class="max-w-2xl mx-auto px-6">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <!-- Email Card -->
    <div
      class="contact-card relative rounded-xl p-8"
      style="background: rgba(14,17,23,0.6); backdrop-filter: blur(4px); border: 1px solid rgba(108,99,255,0.2); transition: all 0.3s ease;"
    >
      <!-- Copy button -->
      <button
        class="copy-btn absolute top-4 right-4 p-2 rounded-lg transition-colors duration-200 flex items-center gap-1"
        style="color: #888; background: transparent; border: none; cursor: pointer;"
        data-copy="sulphur@hamilton.garden"
        aria-label="Copy email address"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span class="copy-tooltip text-xs" style="opacity: 0; transition: opacity 0.2s ease; pointer-events: none;">Copied!</span>
      </button>

      <!-- Icon -->
      <div class="mb-4">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6c63ff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>

      <p class="text-xs uppercase tracking-widest font-mono mb-2" style="color: #888;">Email</p>
      <a
        href="mailto:sulphur@hamilton.garden"
        class="text-xl font-semibold no-underline transition-colors duration-200 break-all"
        style="color: #f0f0f0;"
        onmouseover="this.style.color='#6c63ff'"
        onmouseout="this.style.color='#f0f0f0'"
      >
        sulphur@hamilton.garden
      </a>
    </div>

    <!-- GitHub Card -->
    <div
      class="contact-card relative rounded-xl p-8"
      style="background: rgba(14,17,23,0.6); backdrop-filter: blur(4px); border: 1px solid rgba(108,99,255,0.2); transition: all 0.3s ease;"
    >
      <!-- Icon -->
      <div class="mb-4">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="#6c63ff" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </div>

      <p class="text-xs uppercase tracking-widest font-mono mb-2" style="color: #888;">GitHub</p>
      <a
        href="https://github.com/sulphur-swarm"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xl font-semibold no-underline transition-colors duration-200 flex items-center gap-2"
        style="color: #f0f0f0;"
        onmouseover="this.style.color='#6c63ff'"
        onmouseout="this.style.color='#f0f0f0'"
      >
        github.com/sulphur-swarm
        <span aria-hidden="true" style="font-size: 1rem; opacity: 0.6;">→</span>
      </a>
    </div>
  </div>

  <p class="text-center text-sm mt-6" style="color: #888;">We typically respond within 24–48 hours.</p>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Card hover effects
  document.querySelectorAll<HTMLElement>('.contact-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.style.transform = 'translateY(-2px)';
      card.style.borderColor = 'rgba(108,99,255,0.4)';
      card.style.boxShadow = '0 0 30px rgba(108,99,255,0.15)';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
      card.style.borderColor = 'rgba(108,99,255,0.2)';
      card.style.boxShadow = '';
    });
  });

  // Scroll reveal
  gsap.fromTo(
    '.contact-card',
    { opacity: 0, y: 30 },
    {
      opacity: 1,
      y: 0,
      duration: 0.6,
      stagger: 0.15,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '.contact-card',
        start: 'top 85%',
        once: true,
      },
    }
  );

  // Copy to clipboard
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const tooltip = btn.querySelector<HTMLElement>('.copy-tooltip');
        if (tooltip) {
          tooltip.style.opacity = '1';
          setTimeout(() => {
            tooltip.style.opacity = '0';
          }, 1500);
        }
      } catch (err) {
        console.warn('Clipboard write failed:', err);
      }
    });

    // Hover color effect
    btn.addEventListener('mouseenter', () => { btn.style.color = '#6c63ff'; });
    btn.addEventListener('mouseleave', () => { btn.style.color = '#888'; });
  });
</script>
