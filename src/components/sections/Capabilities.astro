---
// src/components/sections/Capabilities.astro

const capabilities = [
  {
    title: 'Autonomous Coding',
    description:
      'Writes, tests, refactors, and debugs production-quality software end-to-end — no human in the loop required.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>`,
  },
  {
    title: 'Deep Research',
    description:
      'Multi-source research with automatic synthesis, cross-validation, and structured reporting across any domain.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>`,
  },
  {
    title: 'Swarm Coordination',
    description:
      'Hierarchical orchestration of specialist agents — Overseers, Coordinators, Researchers, Workers — operating in concert.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM6 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM18 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12M6 12h12" /></svg>`,
  },
  {
    title: 'Built-in Validation',
    description:
      'Every output passes through dedicated review and validation agents before delivery — quality assurance is structural.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>`,
  },
  {
    title: '24/7 Operation',
    description:
      'The swarm runs continuously with no downtime, no fatigue, and no loss of context between sessions.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
  },
  {
    title: 'Task Parallelization',
    description:
      'Dozens of independent workstreams execute simultaneously, compressing days of work into hours.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>`,
  },
];
---

<section class="capabilities-section" id="capabilities">
  <div class="max-w-6xl mx-auto px-6 py-32 lg:py-40">

    <!-- Section header -->
    <div class="capabilities-header mb-16 max-w-2xl">
      <p class="text-sm font-mono tracking-widest uppercase mb-6"
         style="color: var(--color-accent-secondary);">
        Capabilities
      </p>
      <h2 class="text-4xl lg:text-5xl font-extrabold leading-tight"
          style="color: var(--color-text-primary);">
        Built for problems<br />that don't have easy answers.
      </h2>
    </div>

    <!-- Capabilities grid -->
    <div class="capabilities-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {capabilities.map((cap) => (
        <div class="capability-card p-8 rounded-2xl border transition-all duration-300"
             style="background: var(--color-surface); border-color: var(--color-border);">

          <!-- Icon wrapper -->
          <div class="icon-wrapper mb-6 w-12 h-12 rounded-xl flex items-center justify-center"
               style="background: rgba(108, 99, 255, 0.12); color: var(--color-accent-primary);"
               set:html={cap.icon} />

          <!-- Title -->
          <h3 class="text-lg font-bold mb-3" style="color: var(--color-text-primary);">
            {cap.title}
          </h3>

          <!-- Description -->
          <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            {cap.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .capability-card:hover {
    border-color: rgba(108, 99, 255, 0.4);
    box-shadow: 0 0 0 1px rgba(108, 99, 255, 0.15), 0 8px 32px rgba(108, 99, 255, 0.08);
    transform: translateY(-2px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Animate section header
  gsap.from('.capabilities-header', {
    scrollTrigger: {
      trigger: '#capabilities',
      start: 'top 80%',
      once: true,
    },
    opacity: 0,
    y: 40,
    duration: 1.0,
    ease: 'power2.out',
  });

  // Stagger capability cards
  gsap.from('.capability-card', {
    scrollTrigger: {
      trigger: '.capabilities-grid',
      start: 'top 75%',
      once: true,
    },
    opacity: 0,
    y: 30,
    scale: 0.97,
    duration: 0.8,
    ease: 'power2.out',
    stagger: 0.1,
  });
</script>
