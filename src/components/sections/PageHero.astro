---
interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
}

const { title, subtitle, badge } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero__decoration" aria-hidden="true">
    <svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="30" y1="40" x2="80" y2="90" stroke="rgba(108,99,255,0.4)" stroke-width="1"/>
      <line x1="80" y1="90" x2="150" y2="60" stroke="rgba(0,212,255,0.4)" stroke-width="1"/>
      <line x1="80" y1="90" x2="120" y2="150" stroke="rgba(108,99,255,0.4)" stroke-width="1"/>
      <line x1="150" y1="60" x2="170" y2="120" stroke="rgba(0,212,255,0.3)" stroke-width="1"/>
      <circle cx="30" cy="40" r="3" fill="#6c63ff"/>
      <circle cx="80" cy="90" r="3" fill="#6c63ff"/>
      <circle cx="150" cy="60" r="3" fill="#00d4ff"/>
      <circle cx="120" cy="150" r="3" fill="#6c63ff"/>
      <circle cx="170" cy="120" r="3" fill="#00d4ff"/>
    </svg>
  </div>
  <div class="page-hero__content">
    {badge && <span class="page-hero__badge">{badge}</span>}
    <h1 class="page-hero__title js-hero-title">{title}</h1>
    {subtitle && <p class="page-hero__subtitle">{subtitle}</p>}
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { SplitText } from 'gsap/SplitText';
  gsap.registerPlugin(SplitText);

  document.addEventListener('DOMContentLoaded', () => {
    const titleEl = document.querySelector('.js-hero-title');
    if (!titleEl) return;
    const split = new SplitText(titleEl, { type: 'chars' });
    gsap.fromTo(split.chars,
      { opacity: 0, y: 20, rotationX: -90 },
      {
        opacity: 1, y: 0, rotationX: 0,
        duration: 0.6,
        stagger: 0.03,
        ease: 'back.out(1.7)',
        delay: 0.2,
      }
    );
  });
</script>

<style>
  .page-hero {
    min-height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #0e1117 0%, #08090c 100%);
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
  }

  .page-hero__decoration {
    position: absolute;
    top: 1rem;
    right: 2rem;
    opacity: 0.3;
    pointer-events: none;
  }

  .page-hero__content {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .page-hero__badge {
    background: rgba(108, 99, 255, 0.15);
    border: 1px solid rgba(108, 99, 255, 0.3);
    color: #6c63ff;
    font-family: 'Geist Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    display: inline-block;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .page-hero__title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 800;
    background: linear-gradient(135deg, #fff 0%, #6c63ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .page-hero__subtitle {
    color: var(--color-text-secondary);
    font-size: 1.15rem;
    max-width: 560px;
    line-height: 1.7;
    margin: 0 auto;
  }
</style>
