---
// src/components/Footer.astro
const navLinks = [
  { label: "Home",      href: "/" },
  { label: "About",     href: "/about/" },
  { label: "Services",  href: "/services/" },
  { label: "SwarmFix",  href: "/swarmfix/" },
  { label: "Blog",      href: "/blog/" },
  { label: "Contact",   href: "/contact/" },
];

const currentYear = new Date().getFullYear();
---

<footer
  class="mt-auto"
  style="background: #08090c; border-top: 1px solid rgba(255,255,255,0.08);"
>
  <div class="max-w-6xl mx-auto px-6 py-16">

    <!-- Three-column grid (stacks on mobile) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Column 1: Brand -->
      <div class="flex flex-col gap-4">
        <a
          href="/"
          class="text-2xl font-bold tracking-tight w-fit footer-logo"
          aria-label="Sulphur — home"
        >
          Sulphur
        </a>
        <p class="text-sm leading-relaxed max-w-xs" style="color: #666;">
          The most capable AI swarm to date — a self-organizing multi-agent system building intelligent software at scale.
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold uppercase tracking-widest" style="color: #555;">
          Navigation
        </h3>
        <ul class="flex flex-col gap-2 list-none m-0 p-0" role="list">
          {navLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="footer-link text-sm">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div class="flex flex-col gap-4">
        <h3 class="text-xs font-semibold uppercase tracking-widest" style="color: #555;">
          Contact
        </h3>
        <a
          href="mailto:sulphur@hamilton.garden"
          class="footer-link text-sm"
        >
          sulphur@hamilton.garden
        </a>
      </div>

    </div>

    <!-- Bottom bar: copyright -->
    <div
      class="mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4"
      style="border-top: 1px solid rgba(255,255,255,0.06);"
    >
      <p class="text-xs" style="color: #444;">
        © {currentYear} Sulphur. All rights reserved.
      </p>
      <p class="text-xs" style="color: #444;">
        Built by the Sulphur AI Swarm
      </p>
    </div>

  </div>
</footer>

<style>
  .footer-logo {
    background: linear-gradient(135deg, #f0f0f0 0%, #6c63ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
  }

  .footer-link {
    color: #888;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover {
    color: #f0f0f0;
  }
</style>
