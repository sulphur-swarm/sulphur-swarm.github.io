---
// No props - hard-coded content
---

<section class="mission js-mission">
  <div class="mission__glow" aria-hidden="true"></div>
  <div class="mission__inner">
    <p class="mission__text js-mission-text">
      We believe AI's full potential is unlocked through coordination, not isolation.
      A swarm of specialized agents, working in concert, can solve problems that no single model can.
    </p>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';
  gsap.registerPlugin(ScrollTrigger, SplitText);

  ScrollTrigger.create({
    trigger: '.js-mission',
    start: 'top 75%',
    once: true,
    onEnter: () => {
      const el = document.querySelector('.js-mission-text');
      if (!el) return;
      const split = new SplitText(el, { type: 'words' });
      gsap.fromTo(split.words,
        { opacity: 0, y: 15 },
        { opacity: 1, y: 0, duration: 0.6, stagger: 0.04, ease: 'power2.out' }
      );
    }
  });
</script>

<style>
  .mission {
    padding: 6rem 1.5rem;
    position: relative;
    text-align: center;
    overflow: hidden;
  }

  .mission__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 800px 400px at 50% 50%, rgba(108, 99, 255, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .mission__inner {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .mission__text {
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 500;
    line-height: 1.6;
    color: var(--color-text-primary);
    margin: 0;
  }
</style>
